{
  "dashboard": {
    "title": "Kubernetes Cluster Overview",
    "tags": ["kubernetes", "infrastructure"],
    "panels": [
      {
        "title": "Cluster CPU Usage",
        "type": "gauge",
        "targets": [{"expr": "1 - avg(rate(node_cpu_seconds_total{mode='idle'}[5m]))"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [
          {"color": "green", "value": 0},
          {"color": "yellow", "value": 0.7},
          {"color": "red", "value": 0.85}
        ]}, "unit": "percentunit", "max": 1}}
      },
      {
        "title": "Cluster Memory Usage",
        "type": "gauge",
        "targets": [{"expr": "1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes)"}]
      },
      {
        "title": "Pod Count by Namespace",
        "type": "piechart",
        "targets": [{"expr": "count(kube_pod_info) by (namespace)", "legendFormat": "{{ namespace }}"}]
      },
      {
        "title": "Pod Restart Rate",
        "type": "timeseries",
        "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total[1h])) by (pod)", "legendFormat": "{{ pod }}"}]
      },
      {
        "title": "Network I/O by Pod",
        "type": "timeseries",
        "targets": [
          {"expr": "sum(rate(container_network_receive_bytes_total{namespace='app'}[5m])) by (pod)", "legendFormat": "rx {{ pod }}"},
          {"expr": "sum(rate(container_network_transmit_bytes_total{namespace='app'}[5m])) by (pod)", "legendFormat": "tx {{ pod }}"}
        ]
      }
    ]
  }
}
