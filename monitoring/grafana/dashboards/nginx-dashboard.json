{
  "dashboard": {
    "title": "NGINX Monitoring",
    "tags": ["nginx", "proxy"],
    "panels": [
      {
        "title": "Requests per Second",
        "type": "timeseries",
        "targets": [
          {"expr": "sum(rate(nginx_http_requests_total[5m])) by (status)", "legendFormat": "{{ status }}"}
        ]
      },
      {
        "title": "Active Connections",
        "type": "stat",
        "targets": [{"expr": "sum(nginx_connections_active)"}]
      },
      {
        "title": "Response Time (p95)",
        "type": "timeseries",
        "targets": [
          {"expr": "histogram_quantile(0.95, sum(rate(nginx_http_request_duration_seconds_bucket[5m])) by (le))"}
        ]
      },
      {
        "title": "Upstream Errors",
        "type": "timeseries",
        "targets": [
          {"expr": "sum(rate(nginx_http_requests_total{status=~'5..'}[5m]))"}
        ]
      }
    ]
  }
}
